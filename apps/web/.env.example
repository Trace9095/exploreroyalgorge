# ============================================================
# Explore Royal Gorge — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ------------------------------------------------------------
# DATABASE (Neon Postgres — required)
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ------------------------------------------------------------
# STRIPE (required for paid listing checkout)
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PREMIUM_PRICE_ID=price_...
STRIPE_SPONSORED_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ------------------------------------------------------------
# RESEND (optional — email notifications)
# ------------------------------------------------------------
RESEND_API_KEY=re_...

# ------------------------------------------------------------
# JWT AUTH (admin dashboard)
# ------------------------------------------------------------
JWT_SECRET=your-secret-here
ADMIN_EMAIL=CEO@epicai.ai

# ------------------------------------------------------------
# APP URL
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://exploreroyalgorge.com

# Google Analytics 4 — add your Measurement ID from analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Ads conversion tracking (optional)
NEXT_PUBLIC_GADS_ID=
