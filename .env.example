# Database — Neon PostgreSQL (create project at neon.tech or via Vercel Storage)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth — generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here

# Resend — email sending (resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Stripe — payments (dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx

# Stripe Price IDs — create in Stripe Dashboard
STRIPE_PRICE_PREMIUM=price_xxxxxxxxxxxx       # $99/mo Premium listing
STRIPE_PRICE_SPONSORED=price_xxxxxxxxxxxx     # $199/mo Sponsored listing

# App URL
NEXT_PUBLIC_APP_URL=https://exploreroyalgorge.com

# Admin email (receives listing request notifications)
ADMIN_EMAIL=CEO@epicai.ai
